APP_NAME="Yantra Voice Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/Yantravoice/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── SQLite (default — no MySQL needed) ──
DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/your/database/database.sqlite

# ── MySQL (optional — uncomment to use instead of SQLite) ──
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=yantra_voice
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

FILESYSTEM_DISK=local
